{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "uni",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "string_directive"
          },
          {
            "type": "SYMBOL",
            "name": "langdef_directive"
          },
          {
            "type": "SYMBOL",
            "name": "include_directive"
          },
          {
            "type": "SYMBOL",
            "name": "font_directive"
          },
          {
            "type": "SYMBOL",
            "name": "fontdef_directive"
          },
          {
            "type": "SYMBOL",
            "name": "ctrlchar_directive"
          }
        ]
      }
    },
    "string_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#string"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "language_entry"
          }
        }
      ]
    },
    "language_entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#language"
        },
        {
          "type": "FIELD",
          "name": "code",
          "content": {
            "type": "SYMBOL",
            "name": "language_code"
          }
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "string"
          }
        }
      ]
    },
    "langdef_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#langdef"
        },
        {
          "type": "FIELD",
          "name": "code",
          "content": {
            "type": "SYMBOL",
            "name": "language_code"
          }
        },
        {
          "type": "FIELD",
          "name": "description",
          "content": {
            "type": "SYMBOL",
            "name": "string"
          }
        }
      ]
    },
    "include_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#include"
        },
        {
          "type": "FIELD",
          "name": "path",
          "content": {
            "type": "SYMBOL",
            "name": "string"
          }
        }
      ]
    },
    "font_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#font"
        },
        {
          "type": "FIELD",
          "name": "id",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        }
      ]
    },
    "fontdef_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#fontdef"
        },
        {
          "type": "FIELD",
          "name": "id",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "string"
          }
        },
        {
          "type": "FIELD",
          "name": "size",
          "content": {
            "type": "SYMBOL",
            "name": "number"
          }
        },
        {
          "type": "FIELD",
          "name": "styles",
          "content": {
            "type": "SYMBOL",
            "name": "string"
          }
        }
      ]
    },
    "ctrlchar_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "/="
        },
        {
          "type": "FIELD",
          "name": "char",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "IMMEDIATE_TOKEN",
              "content": {
                "type": "PATTERN",
                "value": "\\S"
              }
            },
            "named": true,
            "value": "control_char"
          }
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z][A-Za-z0-9_-]*"
    },
    "language_code": {
      "type": "PATTERN",
      "value": "[A-Za-z]{1,8}(-[A-Za-z0-9]{1,8})*"
    },
    "number": {
      "type": "PATTERN",
      "value": "[0-9]+"
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\"[^\\r\\n]*\""
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\\/\\/[^\\n]*"
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}