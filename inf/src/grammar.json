{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "inf",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "section"
      }
    },
    "section": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "section_header"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_item"
          }
        }
      ]
    },
    "section_header": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "SYMBOL",
          "name": "tag"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "tag"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "tag_segment"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "."
              },
              {
                "type": "SYMBOL",
                "name": "tag_segment"
              }
            ]
          }
        }
      ]
    },
    "tag_segment": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        }
      ]
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "define_statement"
        },
        {
          "type": "SYMBOL",
          "name": "depex_expression"
        },
        {
          "type": "SYMBOL",
          "name": "statement"
        }
      ]
    },
    "define_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "DEFINE"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "value"
          }
        }
      ]
    },
    "statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "field"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "="
                    },
                    {
                      "type": "FIELD",
                      "name": "value",
                      "content": {
                        "type": "SYMBOL",
                        "name": "value"
                      }
                    }
                  ]
                },
                {
                  "type": "REPEAT1",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "STRING",
                        "value": "|"
                      },
                      {
                        "type": "FIELD",
                        "name": "value",
                        "content": {
                          "type": "SYMBOL",
                          "name": "pipe_field"
                        }
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "depex_expression": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "SOR"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "depex_and"
            },
            {
              "type": "SYMBOL",
              "name": "depex_or"
            },
            {
              "type": "SYMBOL",
              "name": "depex_not"
            },
            {
              "type": "SYMBOL",
              "name": "depex_before"
            },
            {
              "type": "SYMBOL",
              "name": "depex_after"
            },
            {
              "type": "SYMBOL",
              "name": "depex_push"
            }
          ]
        }
      ]
    },
    "_depex_expr": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "field"
        },
        {
          "type": "SYMBOL",
          "name": "depex_and"
        },
        {
          "type": "SYMBOL",
          "name": "depex_or"
        },
        {
          "type": "SYMBOL",
          "name": "depex_not"
        },
        {
          "type": "SYMBOL",
          "name": "depex_paren"
        }
      ]
    },
    "depex_and": {
      "type": "PREC_LEFT",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_depex_expr"
          },
          {
            "type": "STRING",
            "value": "AND"
          },
          {
            "type": "SYMBOL",
            "name": "_depex_expr"
          }
        ]
      }
    },
    "depex_or": {
      "type": "PREC_LEFT",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_depex_expr"
          },
          {
            "type": "STRING",
            "value": "OR"
          },
          {
            "type": "SYMBOL",
            "name": "_depex_expr"
          }
        ]
      }
    },
    "depex_not": {
      "type": "PREC",
      "value": 3,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "NOT"
          },
          {
            "type": "SYMBOL",
            "name": "_depex_expr"
          }
        ]
      }
    },
    "depex_before": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "BEFORE"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "field"
          }
        }
      ]
    },
    "depex_after": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "AFTER"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "field"
          }
        }
      ]
    },
    "depex_push": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "PUSH"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "field"
          }
        }
      ]
    },
    "depex_paren": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "SYMBOL",
          "name": "_depex_expr"
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "field": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "array"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "compound_word"
        }
      ]
    },
    "compound_word": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "macro_invocation"
            },
            {
              "type": "SYMBOL",
              "name": "bare_word"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_macro_invocation_immediate"
              },
              {
                "type": "SYMBOL",
                "name": "_bare_word_immediate"
              }
            ]
          }
        }
      ]
    },
    "pipe_field": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "array"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "macro_invocation"
                },
                {
                  "type": "ALIAS",
                  "content": {
                    "type": "SYMBOL",
                    "name": "_bare_word_or_empty"
                  },
                  "named": true,
                  "value": "bare_word"
                }
              ]
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_macro_invocation_immediate"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "_bare_word_immediate"
                  }
                ]
              }
            }
          ]
        }
      ]
    },
    "_bare_word_or_empty": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\s#|=,\\[\\]{}$\"]*"
      }
    },
    "array": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "field"
                },
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "STRING",
                        "value": ","
                      },
                      {
                        "type": "SYMBOL",
                        "name": "field"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "macro_invocation": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "$("
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "_macro_invocation_immediate": {
      "type": "ALIAS",
      "content": {
        "type": "SYMBOL",
        "name": "_immediate_macro_invocation_body"
      },
      "named": true,
      "value": "macro_invocation"
    },
    "_immediate_macro_invocation_body": {
      "type": "SEQ",
      "members": [
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": "$("
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "bare_word": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\s#|=,\\[\\]{}$\"]+"
      }
    },
    "_bare_word_immediate": {
      "type": "ALIAS",
      "content": {
        "type": "IMMEDIATE_TOKEN",
        "content": {
          "type": "PATTERN",
          "value": "[^\\s#|=,\\[\\]{}$\"]+"
        }
      },
      "named": true,
      "value": "bare_word"
    },
    "value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "array"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "macro_invocation"
                },
                {
                  "type": "SYMBOL",
                  "name": "raw_text"
                }
              ]
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_macro_invocation_immediate"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "_raw_text_immediate"
                  }
                ]
              }
            }
          ]
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_empty_value"
          },
          "named": true,
          "value": "raw_text"
        }
      ]
    },
    "raw_text": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\s\\n#{}\"$][^\\n#{}\"$]*"
      }
    },
    "_empty_value": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "(?:)"
        }
      }
    },
    "_raw_text_immediate": {
      "type": "ALIAS",
      "content": {
        "type": "IMMEDIATE_TOKEN",
        "content": {
          "type": "PATTERN",
          "value": "[^\\n#{}\"$]+"
        }
      },
      "named": true,
      "value": "raw_text"
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "L?\"[^\"\\n]*\""
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "#[^\\n]*"
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}